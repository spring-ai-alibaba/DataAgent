# Copy this file to .env (or export env vars) before running.
# Model access
AI_DASHSCOPE_API_KEY=REPLACE_ME
API_BASE_URL=REPLACE_ME

# Management service datasource
DATA_AGENT_DATASOURCE_PASSWORD=REPLACE_ME
DATA_AGENT_DATASOURCE_SQL_INIT=REPLACE_ME
DATA_AGENT_DATASOURCE_URL=REPLACE_ME
DATA_AGENT_DATASOURCE_USERNAME=REPLACE_ME

# Frontend runtime
ECHARTS_URL=REPLACE_ME
MARKED_URL=REPLACE_ME
NODE_ENV=REPLACE_ME

# Optional observability
LANGFUSE_ENABLED=REPLACE_ME
LANGFUSE_HOST=REPLACE_ME
LANGFUSE_PUBLIC_KEY=REPLACE_ME
LANGFUSE_SECRET_KEY=REPLACE_ME

# Local docker-compose helpers
MYSQL_PASSWORD=REPLACE_ME
MYSQL_USERNAME=REPLACE_ME

# Optional object storage
OSS_ACCESS_KEY_ID=REPLACE_ME
OSS_ACCESS_KEY_SECRET=REPLACE_ME
OSS_BUCKET_NAME=REPLACE_ME
OSS_CUSTOM_DOMAIN=REPLACE_ME
OSS_ENDPOINT=REPLACE_ME

# Shell passthrough
PATH=REPLACE_ME
